# Ganache RPC (GUI defaults to 7545, CLI to 8545)
GANACHE_RPC=http://127.0.0.1:7545

# Private key of the RELAYER account. This account submits students' votes
# on-chain on their behalf. It MUST be the address set as the contract's
# relayer (or an official). Copy a private key from your Ganache "Accounts"
# tab. Use a DIFFERENT account than your officials for clean separation.
RELAYER_PRIVATE_KEY=

# Where the deploy step wrote the address + ABI. Default points at the shared
# file produced by `npm run deploy` in ../contracts.
DEPLOYMENT_FILE=../shared/BVS.json

# Port for this API
PORT=4000
