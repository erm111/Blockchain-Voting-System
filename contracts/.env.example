# Ganache RPC endpoint (GUI defaults to 7545, CLI to 8545)
GANACHE_RPC=http://127.0.0.1:7545

# Optional: deployer private key (else Hardhat uses Ganache's exposed accounts).
# Paste a private key from your Ganache "Accounts" tab (the first account is fine).
DEPLOYER_PRIVATE_KEY=

# Optional: dedicated backend relayer address (a separate Ganache account).
# The relayer is the only non-official account allowed to submit votes.
RELAYER_ADDRESS=

# Optional: comma-separated extra official addresses to grant the official role.
EXTRA_OFFICIALS=

# ---- Public testnet (Sepolia) deploy ----
# Leave SEPOLIA_RPC_URL blank to use a free public RPC, or paste an Alchemy/Infura URL.
SEPOLIA_RPC_URL=
# A Sepolia-funded account's private key (deployer = owner + official + relayer).
# Use a DEDICATED throwaway account — never a wallet holding real funds.
# (On Sepolia this same DEPLOYER_PRIVATE_KEY is reused above.)
# Optional separate relayer key (else the deployer also relays):
# RELAYER_PRIVATE_KEY=
# Optional: free API key from etherscan.io to verify the contract source.
ETHERSCAN_API_KEY=
